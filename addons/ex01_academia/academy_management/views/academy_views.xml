<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_academy_student_tree" model="ir.ui.view">
        <field name="name">academy.student.tree</field>
        <field name="model">academy.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="name"/>
                <field name="email"/>
                <field name="state"/>
                <field name="tutoring_count"/>
                <field name="last_tutoring_date"/>
            </list>
        </field>
    </record>

    <record id="view_academy_student_form" model="ir.ui.view">
        <field name="name">academy.student.form</field>
        <field name="model">academy.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="state"/>
                    </group>
                    <group string="Tutoring Statistics">
                        <field name="tutoring_count"/>
                        <field name="last_tutoring_date"/>
                    </group>
                    <group string="Tutorings">
                        <field name="tutoring_ids" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_academy_tutoring_tree" model="ir.ui.view">
        <field name="name">academy.tutoring.tree</field>
        <field name="model">academy.tutoring</field>
        <field name="arch" type="xml">
            <list string="Tutorings">
                <field name="name"/>
                <field name="date"/>
                <field name="student_id"/>
            </list>
        </field>
    </record>

    <record id="view_academy_tutoring_form" model="ir.ui.view">
        <field name="name">academy.tutoring.form</field>
        <field name="model">academy.tutoring</field>
        <field name="arch" type="xml">
            <form string="Tutoring">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="student_id"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_academy_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">academy.student</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_academy_tutoring" model="ir.actions.act_window">
        <field name="name">Tutorings</field>
        <field name="res_model">academy.tutoring</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_academy_root" name="Academy" sequence="10"/>

    <menuitem id="menu_academy_students" name="Students"
              parent="menu_academy_root"
              action="action_academy_student"/>

    <menuitem id="menu_academy_tutorings" name="Tutorings"
              parent="menu_academy_root"
              action="action_academy_tutoring"/>
</odoo>